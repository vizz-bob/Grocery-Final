# ─── SENSITIVE / SECRET FILES ────────────────────────────────────────────────

# Environment & config files with secrets
.env
.env.*
*.env
env.dart
lib/config/app_config.dart

# Firebase / Google Services
google-services.json
GoogleService-Info.plist
firebase_options.dart

# iOS signing & certificates
*.p12
*.cer
*.mobileprovision
ios/Runner/ExportOptions.plist

# Android signing
android/key.properties
android/app/*.jks
android/app/*.keystore
*.keystore
*.jks

# API keys / credentials files
**/secrets.dart
**/keys.dart
**/credentials.dart
secrets.json

# CocoaPods (generated, not needed in git)
ios/Pods/
ios/.symlinks/
ios/Podfile.lock

# macOS
**/.DS_Store
*.xcuserstate
ios/**/*.xcuserstate
ios/Runner.xcworkspace/xcuserdata/

# Xcode derived data & archives
ios/DerivedData/
*.xcarchive

# Test user scripts (should never be in git)
insert_test_user.php
*test_user*.php
